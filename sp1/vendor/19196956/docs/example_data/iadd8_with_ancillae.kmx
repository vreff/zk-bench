# Performs r0 += r1 (mod 256) with help from clean ancilla qubits.
# This is a variant of the adder from https://arxiv.org/abs/1709.06648
APPEND_TO_REGISTER q0 r0
APPEND_TO_REGISTER q1 r0
APPEND_TO_REGISTER q2 r0
APPEND_TO_REGISTER q3 r0
APPEND_TO_REGISTER q4 r0
APPEND_TO_REGISTER q5 r0
APPEND_TO_REGISTER q6 r0
APPEND_TO_REGISTER q7 r0
REGISTER r0
APPEND_TO_REGISTER q8 r1
APPEND_TO_REGISTER q9 r1
APPEND_TO_REGISTER q10 r1
APPEND_TO_REGISTER q11 r1
APPEND_TO_REGISTER q12 r1
APPEND_TO_REGISTER q13 r1
APPEND_TO_REGISTER q14 r1
APPEND_TO_REGISTER q15 r1
REGISTER r1
CX q15 q7
R q16
CCX q0 q8 q16
CX q16 q9
CX q16 q1
R q17
CCX q1 q9 q17
CX q17 q16
CX q16 q10
CX q16 q2
R q18
CCX q2 q10 q18
CX q18 q16
CX q16 q11
CX q16 q3
R q19
CCX q3 q11 q19
CX q19 q16
CX q16 q12
CX q16 q4
R q20
CCX q4 q12 q20
CX q20 q16
CX q16 q13
CX q16 q5
R q21
CCX q5 q13 q21
CX q21 q16
CX q16 q14
CX q16 q6
CX q16 q7
CCX q6 q14 q7
CX q16 q14
CX q14 q6
CX q21 q16
HMR q21 b0
CZ q5 q13 if b0
CX q16 q13
CX q13 q5
CX q20 q16
HMR q20 b0
CZ q4 q12 if b0
CX q16 q12
CX q12 q4
CX q19 q16
HMR q19 b0
CZ q3 q11 if b0
CX q16 q11
CX q11 q3
CX q18 q16
HMR q18 b0
CZ q2 q10 if b0
CX q16 q10
CX q10 q2
CX q17 q16
HMR q17 b0
CZ q1 q9 if b0
CX q16 q9
CX q9 q1
HMR q16 b0
CZ q0 q8 if b0
CX q8 q0
